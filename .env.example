# ============================================================
# Azure AI Foundry — APIM Gateway
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Azure Identity ─────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
SUBSCRIPTION_ID=your-subscription-id

# ── APIM ──────────────────────────────────────────────────
APIM_RESOURCE_GROUP=rg-apim-prod
APIM_SERVICE_NAME=my-apim-service
APIM_API_ID=foundry-agents
APIM_OPERATION_ID=invoke-agent
APIM_OPERATION_PATH=/agents/invoke
APIM_API_DISPLAY_NAME=Foundry Agent API

# ── Foundry ────────────────────────────────────────────────
FOUNDRY_NAME=my-foundry-dev
FOUNDRY_PROJECT_ID=proj-default

# ── Agent Map ──────────────────────────────────────────────
# JSON map: agentName → assistantId
# Find assistantId: Foundry Portal → Project → Agents → Agent → Copy ID
AGENT_MAP_JSON={"devops":"asst_abc123def456","security":"asst_xyz789"}
USE_CASE_NAME=devops

# ── Client settings ────────────────────────────────────────
APIM_URL=https://my-apim.azure-api.net/foundry-agents/agents/invoke
APIM_SUBSCRIPTION_KEY=your-apim-subscription-key

# ── Auth mode ──────────────────────────────────────────────
# Options: default | cli | system_mi | user_mi | service_principal | certificate
AUTH_MODE=default

# ── User-assigned Managed Identity ────────────────────────
# Required only when AUTH_MODE=user_mi
MANAGED_IDENTITY_CLIENT_ID=

# ── Service Principal ──────────────────────────────────────
# Required only when AUTH_MODE=service_principal
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Certificate ────────────────────────────────────────────
# Required only when AUTH_MODE=certificate
AZURE_CLIENT_CERTIFICATE_PATH=

# ── Test / demo ────────────────────────────────────────────
TEST_AGENT_NAME=devops
TEST_MESSAGE=Hello, what can you help me with today?
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=3
